## 🎯 **Adding New MCP Tools (Best Practices)**

### **1. Follow LanceDB Performance Patterns**
```python
# ✅ BEST PRACTICE: Use cached table objects
from mcp_lancedb.core.connection import get_table_cached, clear_table_cache

@server.call_tool()
async def my_new_tool(table_name: str) -> CallToolResult:
    try:
        # Use cached table for performance
        table = get_table_cached(table_name)
        
        # Apply LanceDB best practices
        result = table.some_operation()
        
        # Clear cache if table was modified
        if operation_modifies_table:
            clear_table_cache(table_name)
            
        return CallToolResult(content=result)
    except Exception as e:
        return CallToolResult(content=f"Error: {e}", is_error=True)
```

### **2. Integration Test First**
```python
# tests/integration/test_my_feature.py
def test_my_new_tool_performance():
    """Test the new tool follows LanceDB best practices."""
    import time
    
    start = time.time()
    result = my_new_tool("test_table")
    elapsed = time.time() - start
    
    # Verify performance (sub-second for best practices)
    assert elapsed < 1.0, f"Tool too slow: {elapsed:.3f}s"
    assert "success" in result.lower()
```

