## 🔧 **Common Tasks (Optimized)**

### **Create New Table Operation**
```python
# Follow this pattern for all new table operations
def new_table_operation(table_name: str, data):
    from mcp_lancedb.core.connection import get_table_cached, clear_table_cache
    from mcp_lancedb.core.config import logger
    
    try:
        # Use cached table
        table = get_table_cached(table_name)
        
        # Perform operation
        result = table.operation(data)
        
        # Clear cache if table structure changed
        if operation_changes_structure:
            clear_table_cache(table_name)
            
        logger.info(f"Operation completed for {table_name}")
        return result
        
    except Exception as e:
        logger.error(f"Operation failed: {e}")
        raise
```

### **Add Performance Monitoring**
```python
def monitor_operation_performance(table_name: str):
    """Add performance monitoring to any operation."""
    import time
    from mcp_lancedb import get_index_stats
    
    start = time.time()
    
    # Your operation here
    result = your_operation(table_name)
    
    elapsed = time.time() - start
    
    # Performance insights
    if elapsed > 0.1:  # Flag slow operations
        stats = get_index_stats(table_name)
        print(f"⚠️ Slow operation: {elapsed:.3f}s")
        if 'optimization_needed' in stats:
            print(f"💡 Optimization opportunity: {stats['optimization_needed']}")
    
    return result
```

## ⚠️ **Common Pitfalls (AVOID)**

### **❌ Anti-Patterns**
```python
# DON'T: Create new connections
db = lancedb.connect(uri)

# DON'T: Open table repeatedly
table = db.open_table(name)

# DON'T: Use sleep delays
time.sleep(0.1)  # Removed - not needed with LanceDB

# DON'T: Filesystem operations
os.listdir(db_path)  # Use db.table_names() instead

# DON'T: Return all columns
results = query.to_list()  # Use .select() instead
```

### **✅ Correct Patterns**
```python
# DO: Use cached connections and tables
from mcp_lancedb.core.connection import get_connection, get_table_cached
db = get_connection()
table = get_table_cached(table_name)

# DO: Use column selection
results = query.select(["doc", "_distance"]).to_list()

# DO: Monitor performance
from mcp_lancedb import get_index_stats, optimize_table
stats = get_index_stats(table_name)
if 'optimization_needed' in stats:
    optimize_table(table_name)
```

